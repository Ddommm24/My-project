    kind: 0
    requiredKey: 0
    startTriggerId: 
  - text: Use WASD to Move
    minimumTime: 0.5
    kind: 1
    requiredKey: 119
    startTriggerId: 
  - text: Hold Shift to Sprint
    minimumTime: 0.5
    kind: 1
    requiredKey: 304
    startTriggerId: 
  - text: Press Space to Jump
    minimumTime: 0
    kind: 1
    requiredKey: 32
    startTriggerId: JumpTrigger
  - text: 'Sometimes it''s best to reset.

      Press V to activate your time loop
      device and reset.'
    minimumTime: 2
    kind: 0
    requiredKey: 0
    startTriggerId: ResetTrigger
  - text: Sometimes you'll need to find an item to progress...
    minimumTime: 2
    kind: 0
    requiredKey: 0
