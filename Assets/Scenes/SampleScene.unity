  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 979758826}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 29385b9fdc618164ba39f56bb3457e5e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::EndingCutsceneManager
  endingChoice: {fileID: 490514875}
  textUI: {fileID: 413155950}
  player: {fileID: 2119570142}
  playerMovement: {fileID: 2119570144}
  walkTarget: {fileID: 9769083}
  walkSpeed: 1
  steps:
  - text: He must be in here...
    duration: 3
    textColor: {r: 0.13283314, g: 0.9411765, b: 0.03137252, a: 1}
  - text: What's that at the end of the room..?
    duration: 4
    textColor: {r: 0.13333334, g: 0.9411765, b: 0.03137255, a: 1}
  - text: What's that at the end of the room...
    duration: 0
    textColor: {r: 0.03137255, g: 0.15686275, b: 0.9411765, a: 1}
  - text: Stay away
    duration: 4
    textColor: {r: 0.9411765, g: 0.03137252, b: 0.5422284, a: 1}
  - text: That isn't Mr Iseman speaking...
    duration: 3
    textColor: {r: 0.13333334, g: 0.9411765, b: 0.03137255, a: 1}
  - text: He is sick, I am saving him
    duration: 3
    textColor: {r: 0.9411765, g: 0.03137255, b: 0.5411765, a: 1}
  - text: As he has saved me
    duration: 4
    textColor: {r: 0.9411765, g: 0.03137255, b: 0.5411765, a: 1}
  - text: He doesn't seem saved...
    duration: 4
    textColor: {r: 0.13333334, g: 0.9411765, b: 0.03137255, a: 1}
  - text: I am keeping him alive
    duration: 3
    textColor: {r: 0.9411765, g: 0.03137255, b: 0.5411765, a: 1}
  - text: So we can stay together
    duration: 4
    textColor: {r: 0.9411765, g: 0.03137255, b: 0.5411765, a: 1}
  - text: I don't think either of you want this
    duration: 3
    textColor: {r: 0.13333334, g: 0.9411765, b: 0.03137255, a: 1}
  - text: You should let go and both be free
    duration: 4
    textColor: {r: 0.13333334, g: 0.9411765, b: 0.03137255, a: 1}
  - text: He kept me alive in this machine
    duration: 3
    textColor: {r: 0.9411765, g: 0.03137255, b: 0.5411765, a: 1}
  - text: I don't think I can let us both die
    duration: 4
    textColor: {r: 0.9411765, g: 0.03137255, b: 0.5411765, a: 1}
  - text: But maybe somebody should...
    duration: 6
    textColor: {r: 0.13333334, g: 0.9411765, b: 0.03137255, a: 1}
